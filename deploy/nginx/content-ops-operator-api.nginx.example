server {
    listen 443 ssl http2;
    server_name ops-api.example.com;

    # Replace with the real certificate paths for the host.
    ssl_certificate /etc/letsencrypt/live/ops-api.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/ops-api.example.com/privkey.pem;

    # Optional hardening. Adjust to your environment.
    add_header X-Content-Type-Options nosniff always;
    add_header X-Frame-Options DENY always;
    add_header Referrer-Policy no-referrer always;

    location / {
        proxy_pass http://127.0.0.1:8765;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Real-IP $remote_addr;
    }
}
